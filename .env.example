# Application Configuration
APP_NAME="GHPIMS"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/ghpims

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ghpims
DB_USERNAME=root
DB_PASSWORD=

# Security
APP_KEY=
SESSION_LIFETIME=30
CSRF_TOKEN_NAME=csrf_token

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# Pagination
ITEMS_PER_PAGE=25

# Logging
LOG_LEVEL=debug
LOG_FILE=storage/logs/app.log

# Email (Optional)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Two-Factor Authentication
TWO_FACTOR_ENABLED=false
