{
    "name": "ghpims/police-management-system",
    "description": "Ghana Police Integrated Management System",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/Controllers/",
            "App\\Models\\": "app/Models/",
            "App\\Services\\": "app/Services/",
            "App\\Middleware\\": "app/Middleware/",
            "App\\Helpers\\": "app/Helpers/",
            "App\\Config\\": "app/Config/",
            "Tests\\": "tests/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "scripts": {
        "test": "phpunit"
    }
}
